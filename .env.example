# ============================================================
# DeclaraAI — Variáveis de Ambiente
# Copie este arquivo para .env e ajuste os valores
# ============================================================

# Banco de dados SQLite (caminho relativo ao diretório de execução)
DATABASE_URL=sqlite:///./data/declaraai.db

# Ollama — LLM local
# Para execução local: http://localhost:11434
# Para Docker Compose: http://ollama:11434
OLLAMA_BASE_URL=http://localhost:11434

# Modelo Ollama a utilizar (deve estar instalado no Ollama)
# Opções: mistral, llama3, llama3.2, phi3, gemma2
OLLAMA_MODELO=mistral

# Modelo de embeddings (sentence-transformers)
# Será baixado automaticamente do HuggingFace na primeira execução
MODELO_EMBEDDINGS=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Caminhos de dados
CAMINHO_CHROMA=./data/chroma_db
CAMINHO_BASE_CONHECIMENTO=./data/knowledge_base
CAMINHO_UPLOADS=./data/uploads

# Configurações de chunking
CHUNK_SIZE=600
CHUNK_OVERLAP=80

# Número de resultados retornados na busca semântica
TOP_K_RESULTADOS=5

# Modo debug (false em produção)
DEBUG=false
